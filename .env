COMPOSE_PROJECT_NAME=claude-sandbox

# Build args
CLAUDE_CODE_VERSION=latest
EAS_CLI_VERSION=latest
GIT_DELTA_VERSION=0.18.2
GO_VERSION=1.24.1
NVM_VERSION=0.40.4
TZ=${TZ:-America/Los_Angeles}
USERNAME=sophie

# Runtime environment
CLAUDE_CONFIG_DIR=/home/sophie/.claude
EDITOR=vim
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
NODE_OPTIONS=--max-old-space-size=4096
POWERLEVEL9K_DISABLE_GITSTATUS=true
SHELL=/bin/zsh
SOPHIE_CLAUDE_SANDBOX=true
VISUAL=vim
